# Copy to .env for local runs. Never commit the populated file.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/shortener
SPRING_DATASOURCE_USERNAME=shortener
SPRING_DATASOURCE_PASSWORD=shortener
REDIS_HOST=localhost
REDIS_PORT=6379
AEGIS_JWT_SECRET=please-change-this-to-a-random-32-byte-secret
AEGIS_JWT_EXPIRY_SECONDS=3600
AEGIS_PUBLIC_BASE_URL=http://localhost:8080
AEGIS_RATELIMIT_LIMIT=100
AEGIS_RATELIMIT_WINDOW_SECONDS=60
# Optional admin bootstrap
AEGIS_ADMIN_USERNAME=
AEGIS_ADMIN_PASSWORD=
